{
  "manifest_version": 3,
  "name": "Probably AI",
  "version": "0.1.0",
  "description": "Flags sociela media posts and comments that were likely AI generated.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "16.png",
    "48": "48.png",
    "128": "128.png"
  },
  "action": {
    "default_icon": {
      "16": "16.png",
      "48": "48.png",
      "128": "128.png"
    },
    "default_popup": "popup.html",
    "default_title": "Probably AI"
  },
  "content_scripts": [
    {
      "matches": [
        "https://reddit.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ],
      "js": [
        "assets/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "baseline-remove-red-eye.svg",
        "baseline-disabled-visible.svg"
      ],
      "matches": [
        "https://reddit.com/*",
        "https://www.reddit.com/*",
        "https://old.reddit.com/*"
      ]
    }
  ]
}
